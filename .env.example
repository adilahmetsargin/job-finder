PORT=8787
VITE_API_URL=http://127.0.0.1:8787

# Optional for AI tailoring.
# Copy this file to .env, then add a Hugging Face token with:
# User permissions -> Inference Providers -> Make calls to Inference Providers
HF_TOKEN=
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_PROVIDER=novita

# Optional job provider API keys.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=

# Optional comma-separated Greenhouse board tokens.
# Example: figma,openai,anthropic,stripe,reddit
GREENHOUSE_BOARDS=
